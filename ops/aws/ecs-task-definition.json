{
  "family": "__TASK_FAMILY__",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "1024",
  "runtimePlatform": {
    "cpuArchitecture": "ARM64",
    "operatingSystemFamily": "LINUX"
  },
  "executionRoleArn": "__EXECUTION_ROLE_ARN__",
  "taskRoleArn": "__TASK_ROLE_ARN__",
  "containerDefinitions": [
    {
      "name": "api",
      "image": "__IMAGE__",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "DJANGO_SETTINGS_MODULE",
          "value": "core.settings.prod"
        },
        {
          "name": "ENVIRONMENT",
          "value": "production"
        },
        {
          "name": "AWS_REGION",
          "value": "__AWS_REGION__"
        },
        {
          "name": "DYNAMODB_REGION",
          "value": "__AWS_REGION__"
        },
        {
          "name": "DYNAMODB_TABLE_PREFIX",
          "value": "__DYNAMODB_TABLE_PREFIX__"
        },
        {
          "name": "PERSISTENCE_MODE",
          "value": "__PERSISTENCE_MODE__"
        },
        {
          "name": "RUN_DATABASE_MIGRATIONS",
          "value": "__RUN_DATABASE_MIGRATIONS__"
        },
        {
          "name": "RUN_INITADMIN",
          "value": "__RUN_INITADMIN__"
        },
        {
          "name": "DB_ENGINE",
          "value": "__DB_ENGINE__"
        },
        {
          "name": "DB_NAME",
          "value": "__DB_NAME__"
        },
        {
          "name": "BACKEND_ORIGIN",
          "value": "__BACKEND_ORIGIN__"
        },
        {
          "name": "ALLOWED_HOSTS",
          "value": "__ALLOWED_HOSTS__"
        },
        {
          "name": "CORS_ALLOWED_ORIGINS",
          "value": "__CORS_ALLOWED_ORIGINS__"
        },
        {
          "name": "CSRF_TRUSTED_ORIGINS",
          "value": "__CSRF_TRUSTED_ORIGINS__"
        },
        {
          "name": "ADMIN_URL_PATH",
          "value": "__ADMIN_URL_PATH__"
        },
        {
          "name": "DJANGO_SUPERUSER_USERNAME",
          "value": "__DJANGO_SUPERUSER_USERNAME__"
        },
        {
          "name": "DJANGO_SUPERUSER_EMAIL",
          "value": "__DJANGO_SUPERUSER_EMAIL__"
        },
        {
          "name": "SESSION_COOKIE_SECURE",
          "value": "true"
        },
        {
          "name": "CSRF_COOKIE_SECURE",
          "value": "true"
        },
        {
          "name": "SECURE_SSL_REDIRECT",
          "value": "false"
        },
        {
          "name": "DYNAMODB_BILLING_MODE",
          "value": "PAY_PER_REQUEST"
        },
        {
          "name": "DYNAMODB_TABLE_CLASS",
          "value": "STANDARD"
        },
        {
          "name": "GUNICORN_WORKERS",
          "value": "1"
        },
        {
          "name": "GUNICORN_THREADS",
          "value": "8"
        },
        {
          "name": "GUNICORN_TIMEOUT",
          "value": "120"
        }
      ],
      "secrets": [
        {
          "name": "SECRET_KEY",
          "valueFrom": "__SECRET_KEY_ARN__"
        },
        {
          "name": "DJANGO_SUPERUSER_PASSWORD",
          "valueFrom": "__DJANGO_SUPERUSER_PASSWORD_ARN__"
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "sqlite-data",
          "containerPath": "/var/lib/mobileid/sqlite",
          "readOnly": false
        }
      ],
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "python -c \"from urllib.request import Request, urlopen; response = urlopen(Request('http://127.0.0.1:8080/health/', headers={'X-Forwarded-Proto': 'https'}), timeout=5); raise SystemExit(0 if response.status == 200 else 1)\" || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "__LOG_GROUP__",
          "awslogs-region": "__AWS_REGION__",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ],
  "volumes": [
    {
      "name": "sqlite-data",
      "efsVolumeConfiguration": {
        "fileSystemId": "__EFS_FILE_SYSTEM_ID__",
        "transitEncryption": "ENABLED",
        "authorizationConfig": {
          "accessPointId": "__EFS_ACCESS_POINT_ID__",
          "iam": "DISABLED"
        }
      }
    }
  ]
}
